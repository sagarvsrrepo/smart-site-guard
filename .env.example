# AWS configuration for IoT and cloud storage
AWS_DEFAULT_REGION=us-east-1
DYNAMODB_TABLE=SmartSiteGuardEvents
IOT_ENDPOINT=your-iot-endpoint.amazonaws.com
IOT_TOPIC_RAW=smartsite/raw
IOT_TOPIC_PROCESSED=smartsite/processed
IOT_CLIENT_ID=smartsite-edge

# Optional local simulator settings
SITE_ID=site-dublin-01
ZONE_ID=zone-A
PUBLISH_INTERVAL_SECONDS=2

# Optional AWS credentials if not using the default credential chain
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY
# AWS_SESSION_TOKEN=YOUR_SESSION_TOKEN
